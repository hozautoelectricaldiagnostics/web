<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Hoz Auto Electrical & Diagnostics | SA's Elite Auto Care</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts: Modern & Bold -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #0a0a0a;
            color: #e0e0e0;
            scroll-behavior: smooth;
        }

        /* black/red/gold/white theme - premium feel */
        :root {
            --black: #0b0b0b;
            --deep-red: #b91c1c;
            --bright-red: #e11d1d;
            --gold: #f5b042;
            --gold-light: #ffcd7e;
            --white: #fefefe;
            --gray-light: #2a2a2a;
            --card-bg: #111111;
            --border-red: #b91c1c55;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1e1e1e;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--deep-red);
            border-radius: 10px;
        }

        h1, h2, h3 {
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .section-title {
            font-size: 2.2rem;
            border-left: 6px solid var(--gold);
            padding-left: 1rem;
            margin-bottom: 2rem;
            color: var(--white);
        }

        .section-title span {
            color: var(--gold);
        }

        /* navbar */
        .navbar {
            background: rgba(10, 10, 10, 0.96);
            backdrop-filter: blur(12px);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            border-bottom: 1px solid var(--border-red);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo h2 {
            font-size: 1.7rem;
            font-weight: 800;
        }
        .logo h2 span:first-child {
            color: var(--gold);
        }
        .logo h2 span:last-child {
            color: var(--deep-red);
        }
        .logo p {
            font-size: 0.7rem;
            letter-spacing: 1px;
            color: #aaa;
        }

        .nav-links a {
            color: #ddd;
            margin-left: 2rem;
            text-decoration: none;
            font-weight: 500;
            transition: 0.2s;
        }
        .nav-links a:hover {
            color: var(--gold);
        }

        /* hero */
        .hero {
            background: linear-gradient(135deg, #0a0a0a 0%, #1c0a0a 100%);
            padding: 4rem 2rem;
            text-align: center;
            border-bottom: 2px solid var(--deep-red);
        }
        .hero h1 {
            font-size: 3rem;
            color: var(--white);
        }
        .hero h1 span {
            color: var(--gold);
        }
        .hero p {
            max-width: 700px;
            margin: 1rem auto;
            font-size: 1.2rem;
            color: #bcbcbc;
        }
        .hero-badge {
            background: var(--deep-red);
            display: inline-block;
            padding: 0.3rem 1.2rem;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: bold;
            margin-bottom: 1rem;
        }

        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 2rem 2rem;
        }

        /* services grid */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.8rem;
            margin-top: 1rem;
        }
        .service-card {
            background: var(--card-bg);
            border: 1px solid #2c2c2c;
            border-radius: 24px;
            padding: 1.8rem;
            transition: all 0.25s ease;
            text-align: center;
        }
        .service-card:hover {
            border-color: var(--gold);
            transform: translateY(-6px);
            box-shadow: 0 20px 30px -12px rgba(185,28,28,0.2);
        }
        .service-icon {
            font-size: 2.8rem;
            color: var(--gold);
            margin-bottom: 1rem;
        }
        .service-card h3 {
            font-size: 1.5rem;
            margin-bottom: 0.8rem;
            color: white;
        }
        .service-card p {
            color: #b0b0b0;
            font-size: 0.9rem;
        }
        .whatsapp-btn {
            display: inline-block;
            margin-top: 1.2rem;
            background: #25D366;
            color: black;
            font-weight: bold;
            padding: 0.5rem 1rem;
            border-radius: 40px;
            text-decoration: none;
            font-size: 0.85rem;
            transition: 0.2s;
        }
        .whatsapp-btn i {
            margin-right: 6px;
        }
        .whatsapp-btn:hover {
            background: #20b859;
            transform: scale(1.02);
        }

        /* diagnostic section */
        .diagnostic-section {
            background: #0e0e0e;
            border-radius: 36px;
            padding: 2rem;
            margin: 2rem 0;
            border: 1px solid #2a2a2a;
            box-shadow: 0 10px 20px rgba(0,0,0,0.6);
        }
        .selector-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 1.8rem;
        }
        .selector-header h2 {
            color: var(--gold);
            font-size: 1.8rem;
        }
        .search-box {
            background: #1e1e1e;
            padding: 0.5rem 1rem;
            border-radius: 60px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            border: 1px solid #333;
        }
        .search-box i {
            color: var(--gold);
        }
        .search-box input {
            background: transparent;
            border: none;
            outline: none;
            color: white;
            font-size: 0.9rem;
            width: 180px;
        }

        /* brand grid (logos + names) */
        .brands-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
            gap: 1rem;
            margin: 2rem 0;
            max-height: 360px;
            overflow-y: auto;
            padding: 0.5rem;
            border-radius: 28px;
            background: #080808;
        }
        .brand-card {
            background: #151515;
            border-radius: 28px;
            padding: 0.8rem 0.4rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid #2c2c2c;
        }
        .brand-card.active-brand {
            border: 2px solid var(--gold);
            background: #1f1a10;
            box-shadow: 0 0 0 2px rgba(245,176,66,0.3);
        }
        .brand-card.disabled-brand {
            opacity: 0.35;
            filter: grayscale(0.4);
            pointer-events: none;
        }
        .brand-logo {
            font-size: 2.2rem;
            margin-bottom: 6px;
        }
        .brand-name {
            font-weight: 600;
            font-size: 0.8rem;
            color: #eee;
        }
        /* form */
        .car-form {
            background: #121212;
            padding: 1.5rem;
            border-radius: 28px;
            margin-top: 1rem;
        }
        .form-row {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .input-group {
            flex: 1;
            min-width: 200px;
        }
        .input-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--gold-light);
        }
        .input-group input, .input-group textarea {
            width: 100%;
            background: #1e1e1e;
            border: 1px solid #333;
            padding: 0.8rem 1rem;
            border-radius: 20px;
            color: white;
            font-family: inherit;
            outline: none;
            transition: 0.2s;
        }
        .input-group input:focus, .input-group textarea:focus {
            border-color: var(--gold);
        }
        textarea {
            resize: vertical;
            min-height: 90px;
        }
        .submit-wa {
            background: var(--deep-red);
            color: white;
            border: none;
            padding: 0.9rem 2rem;
            font-weight: bold;
            border-radius: 60px;
            font-size: 1rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            transition: 0.2s;
        }
        .submit-wa:hover {
            background: var(--gold);
            color: #0a0a0a;
        }
        .info-note {
            font-size: 0.8rem;
            margin-top: 1rem;
            text-align: center;
            color: #aaa;
        }

        footer {
            background: #050505;
            text-align: center;
            padding: 2rem;
            border-top: 1px solid var(--deep-red);
            margin-top: 2rem;
        }

        @media (max-width: 760px) {
            .navbar {
                flex-direction: column;
                gap: 0.8rem;
            }
            .nav-links a {
                margin: 0 0.8rem;
            }
            .section-title {
                font-size: 1.7rem;
            }
        }
        .highlight-gold {
            color: var(--gold);
        }
    </style>
</head>
<body>

<header>
    <nav class="navbar">
        <div class="logo">
            <h2><span>HOZ</span> <span>AUTO</span></h2>
            <p>ELECTRICAL & DIAGNOSTICS | SOUTH AFRICA</p>
        </div>
        <div class="nav-links">
            <a href="#services">Services</a>
            <a href="#car-selector">Diagnostic Tool</a>
