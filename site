</div>

<!-- CAR SELECTOR & DIAGNOSTIC REQUEST - with ALL South African brands -->
<div class="container" id="car-selector">
    <div class="diagnostic-section">
        <div class="selector-header">
            <h2><i class="fas fa-search" style="margin-right: 12px;"></i> Select Your Vehicle (SA Market)</h2>
            <div class="search-box">
                <i class="fas fa-filter"></i>
                <input type="text" id="brandSearch" placeholder="Search brand... (e.g. Toyota, VW)" autocomplete="off">
            </div>
        </div>
        <p style="margin-bottom: 10px;">✅ Choose a brand — only one can be selected, others will be greyed out. Tap brand to select/deselect.</p>
        <div class="brands-grid" id="brandsGrid"></div>

        <div class="car-form">
            <h3 style="color: var(--gold); margin-bottom: 1rem;"><i class="fas fa-clipboard-list"></i> Vehicle Diagnostic Request</h3>
            <div class="form-row">
                <div class="input-group">
                    <label><i class="fas fa-car-side"></i> Selected Brand</label>
                    <input type="text" id="selectedBrandDisplay" readonly placeholder="Click on a brand above" style="background:#252525;">
                </div>
                <div class="input-group">
                    <label><i class="fas fa-tag"></i> Model (write manually)</label>
                    <input type="text" id="carModel" placeholder="e.g. Hilux, Polo, i30, CX-5">
                </div>
            </div>
            <div class="input-group">
                <label><i class="fas fa-exclamation-triangle"></i> Describe the issue / fault</label>
                <textarea id="issueDesc" placeholder="Example: Battery draining, engine light on, no crank, intermittent starting issues, sensor malfunction, electrical short..."></textarea>
            </div>
            <div style="display: flex; justify-content: flex-end; margin-top: 1.2rem;">
                <button class="submit-wa" id="submitDiagnosticBtn"><i class="fab fa-whatsapp"></i> Send Diagnostic Request →</button>
            </div>
            <div class="info-note">
                <i class="fas fa-shield-alt"></i> Your request will open WhatsApp with pre-filled details: Brand, Model & Issue. Our expert team will respond ASAP.
            </div>
        </div>
    </div>
</div>

<!-- footer contact -->
<footer id="contact">
    <div style="max-width: 800px; margin: auto;">
        <i class="fas fa-map-marker-alt" style="color: var(--gold);"></i> <strong>Hoz Auto Electrical & Diagnostics</strong> — Johannesburg, South Africa | <i class="fas fa-phone-alt"></i> +27 71 234 5678<br/>
        <p style="margin-top: 1rem;">© 2025 Hoz Auto — Precision Electrical & Diagnostic Experts | Serving all SA provinces</p>
        <div style="margin-top: 1rem;">
            <a href="https://wa.me/27712345678?text=Hello%20Hoz%20Auto%2C%20I%20need%20assistance%20with%20my%20vehicle" target="_blank" style="color:var(--gold); margin: 0 10px;"><i class="fab fa-whatsapp"></i> WhatsApp Business</a>
        </div>
    </div>
</footer>

<script>
    // ---------- COMPREHENSIVE CAR BRANDS FOUND IN SOUTH AFRICA ----------
    // includes popular local brands, imports, and emerging EV brands
    const carBrandsSA = [
        { name: "Toyota", logo: "🚗", iconClass: "fas fa-car" },
        { name: "Volkswagen", logo: "🚙", iconClass: "fas fa-caravan" },
        { name: "Ford", logo: "🐎", iconClass: "fas fa-horse-head" },
        { name: "Hyundai", logo: "🆎", iconClass: "fas fa-italic" },
        { name: "Kia", logo: "🔑", iconClass: "fas fa-key" },
        { name: "BMW", logo: "🔵", iconClass: "fab fa-bluetooth-b" },
        { name: "Mercedes-Benz", logo: "⭐", iconClass: "fas fa-star" },
        { name: "Audi", logo: "🔘", iconClass: "fas fa-circle" },
        { name: "Nissan", logo: "💨", iconClass: "fas fa-wind" },
        { name: "Honda", logo: "🏎️", iconClass: "fas fa-car-side" },
        { name: "Mazda", logo: "🌀", iconClass: "fas fa-fan" },
        { name: "Suzuki", logo: "🏍️", iconClass: "fas fa-motorcycle" },
        { name: "Renault", logo: "💠", iconClass: "fas fa-diamond" },
        { name: "Chevrolet", logo: "🏁", iconClass: "fas fa-flag-checkered" },
        { name: "Opel", logo: "⚡", iconClass: "fas fa-bolt" },
        { name: "Peugeot", logo: "🦁", iconClass: "fas fa-paw" },
        { name: "Citroën", logo: "🧲", iconClass: "fas fa-magnet" },
        { name: "Land Rover", logo: "🌍", iconClass: "fas fa-globe" },
        { name: "Jaguar", logo: "🐆", iconClass: "fas fa-gem" },
        { name: "Volvo", logo: "⚙️", iconClass: "fas fa-cogs" },
        { name: "Subaru", logo: "⭐", iconClass: "fas fa-star-of-life" },
        { name: "Mitsubishi", logo: "🔺", iconClass: "fas fa-shapes" },
        { name: "Isuzu", logo: "🏔️", iconClass: "fas fa-mountain" },
        { name: "Mahindra", logo: "🌾", iconClass: "fas fa-tractor" },
        { name: "GWM (Great Wall)", logo: "🏯", iconClass: "fas fa-building" },
        { name: "Chery", logo: "🐉", iconClass: "fas fa-dragon" },
        { name: "BAIC", logo: "🏛️", iconClass: "fas fa-landmark" },
        { name: "Haval", logo: "🏞️", iconClass: "fas fa-tree" },
        { name: "Foton", logo: "🚛", iconClass: "fas fa-truck" },
        { name: "Porsche", logo: "🐎", iconClass: "fas fa-crown" },
        { name: "Ferrari", logo: "🐴", iconClass: "fas fa-horse" },
        { name: "Lamborghini", logo: "🐂", iconClass: "fas fa-bull" },
        { name: "Maserati", logo: "🔱", iconClass: "fas fa-trident" },
        { name: "Bentley", logo: "🪽", iconClass: "fas fa-feather" },
        { name: "Rolls-Royce", logo: "🎩", iconClass: "fas fa-crown" },
        { name: "Mini", logo: "🎲", iconClass: "fas fa-cube" },
        { name: "Jeep", logo: "⛰️", iconClass: "fas fa-mountain" },
        { name: "Alfa Romeo", logo: "🐍", iconClass: "fas fa-snake" },
        { name: "Fiat", logo: "🍕", iconClass: "fas fa-utensils" },
        { name: "DS Automobiles", logo: "✨", iconClass: "fas fa-sparkle" },
        { name: "Lexus", logo: "💎", iconClass: "fas fa-gem" },
        { name: "Infiniti", logo: "♾️", iconClass: "fas fa-infinity" },
        { name: "Mahindra", logo: "🌿", iconClass: "fas fa-leaf" },   // duplicate avoidance but fine
        { name: "Tata", logo: "🐘", iconClass: "fas fa-elephant" },
        { name: "BYD", logo: "🔋", iconClass: "fas fa-battery-full" },
        { name: "Volkswagen Commercial", logo: "🚐", iconClass: "fas fa-shuttle-van" },
        { name: "LDV", logo: "📦", iconClass: "fas fa-box" },
        { name: "Chana", logo: "🌠", iconClass: "fas fa-star" }
    ];

    // remove duplicates (just in case Mahindra appears twice, but we keep unique by name)
    const uniqueBrandsMap = new Map();
    carBrandsSA.forEach(b => {
        if (!uniqueBrandsMap.has(b.name)) uniqueBrandsMap.set(b.name, b);
    });
    const southAfricanBrands = Array.from(uniqueBrandsMap.values());

    let selectedBrandName = null;   // currently selected brand
    let currentActiveElement = null;

    // render brand grid with search filter & disabled logic (only one selectable)
    function renderBrands(filterText = "") {
        const grid = document.getElementById("brandsGrid");
        if (!grid) return;
        const filterLower = filterText.toLowerCase().trim();
        const filtered = southAfricanBrands.filter(b => b.name.toLowerCase().includes(filterLower));
        grid.innerHTML = "";
        if (filtered.length === 0) {
            grid.innerHTML = `<div style="grid-column:1/-1; text-align:center; padding:2rem;">🚫 No brands match "${filterText}"</div>`;
            return;
        }
        filtered.forEach(brand => {
            const card = document.createElement("div");
            card.className = "brand-card";
            if (selectedBrandName === brand.name) {
                card.classList.add("active-brand");
            }
            // if a brand is selected globally, disable all cards except the selected one
            if (selectedBrandName !== null && selectedBrandName !== brand.name) {
                card.classList.add("disabled-brand");
            } else {
                card.classList.remove("disabled-brand");
            }
            const logoDiv = document.createElement("div");
            logoDiv.className = "brand-logo";
            logoDiv.innerHTML = brand.logo ? brand.logo : `<i class="${brand.iconClass}"></i>`;
            const nameSpan = document.createElement("div");
            nameSpan.className = "brand-name";
            nameSpan.innerText = brand.name;
            card.appendChild(logoDiv);
            card.appendChild(nameSpan);
            card.addEventListener("click", (e) => {
                e.stopPropagation();
                if (selectedBrandName === brand.name) {
                    // DESELECT: clear selection
                    selectedBrandName = null;
                    document.getElementById("selectedBrandDisplay").value = "";
                    if (currentActiveElement) currentActiveElement.classList.remove("active-brand");
                    currentActiveElement = null;
                    renderBrands(filterText);
                } else {
                    // select new brand
                    selectedBrandName = brand.name;
                    document.getElementById("selectedBrandDisplay").value = brand.name;
                    renderBrands(filterText);
                }
            });
            grid.appendChild(card);
            if (selectedBrandName === brand.name) {
                currentActiveElement = card;
            }
        });
    }

    // search input handler
    const searchInput = document.getElementById("brandSearch");
    if (searchInput) {
        searchInput.addEventListener("input", (e) => {
            renderBrands(e.target.value);
        });
    }

    // initial render
    renderBrands("");

    // ---------- WhatsApp integration ----------
    // South African business number (replace with actual, placeholder)
    const BUSINESS_PHONE = "27712345678";   // format without '+' for South Africa

    function generateWhatsAppLink(service = null, brand, model, issue) {
        let baseMessage = `Hello Hoz Auto Electrical & Diagnostics (SA), I need assistance with my vehicle.`;
        if (brand && brand.trim() !== "") {
            baseMessage += `\n• Brand: ${brand}`;
        }
        if (model && model.trim() !== "") {
            baseMessage += `\n• Model: ${model}`;
        }
        if (issue && issue.trim() !== "") {
            baseMessage += `\n• Issue: ${issue}`;
        }
        if (service && service.trim() !== "") {
            baseMessage += `\n• Requested Service: ${service}`;
        }
        baseMessage += `\n\nPlease get back to me. Thank you!`;
        const encoded = encodeURIComponent(baseMessage);
        return `https://wa.me/${BUSINESS_PHONE}?text=${encoded}`;
    }

    // For service cards: attach WhatsApp with current fields
    const waButtons = document.querySelectorAll(".wa-service");
    waButtons.forEach(btn => {
        btn.addEventListener("click", (e) => {
            e.preventDefault();
            const serviceName = btn.getAttribute("data-service");
            const brandRaw = selectedBrandName ? selectedBrandName : "";
            const modelRaw = document.getElementById("carModel")?.value || "";
            const issueRaw = document.getElementById("issueDesc")?.value || "";
            const waLink = generateWhatsAppLink(serviceName, brandRaw, modelRaw, issueRaw);
            window.open(waLink, "_blank");
        });
    });

    // Diagnostic form submit button
    const submitDiag = document.getElementById("submitDiagnosticBtn");
    if (submitDiag) {
        submitDiag.addEventListener("click", () => {
            const brandVal = selectedBrandName ? selectedBrandName : "";
            const modelVal = document.getElementById("carModel")?.value.trim() || "";
            const issueVal = document.getElementById("issueDesc")?.value.trim() || "";
            if (!brandVal && !modelVal && !issueVal) {
                alert("⚠️ Please select a car brand or provide at least model/issue to proceed.");
                return;
            }
            if (!brandVal) {
                if (!confirm("You haven't selected a brand. Continue anyway with model and issue?")) return;
            }
            const waLink = generateWhatsAppLink(null, brandVal, modelVal, issueVal);
            window.open(waLink, "_blank");
        });
    }

    // final style for disabled brands & active brand
    const style = document.createElement('style');
    style.textContent = `.brand-card.disabled-brand { cursor: not-allowed; opacity: 0.4; filter: grayscale(0.5); transition: 0.1s; } .brand-card:not(.disabled-brand):hover { background: #2c2418; border-color: #f5b04280; } .brand-card.active-brand { background: #2a1f0e; box-shadow: 0 0 0 1px gold; }`;
    document.head.appendChild(style);

    // small console confirm
    console.log("Hoz Auto SA | Loaded with " + southAfricanBrands.length + " local brands");
</script>
</body>
</html>
