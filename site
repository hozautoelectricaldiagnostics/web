<!-- Services Section -->
<div class="container" id="services">
    <h2 class="section-title">What We Do <span>✦</span></h2>
    <div class="services-grid">
        <div class="service-card">
            <div class="service-icon"><i class="fas fa-car-battery"></i></div>
            <h3>Electrical Repairs</h3>
            <p>Alternators, starters, wiring, lighting, and complete vehicle electrical troubleshooting.</p>
            <a href="#" class="whatsapp-btn wa-service" data-service="Electrical Repairs"><i class="fab fa-whatsapp"></i> Inquire via WhatsApp</a>
